# Database
DATABASE_URL="postgresql://user:password@localhost:5432/thirdeye?schema=public"

# Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Feature flags
USE_MOCK=false
AFFILIATES_ENABLED=true

# Lomadee Affiliate API (Buscape/Bondfaro)
# Get credentials at: https://developer.lomadee.com/
LOMADEE_APP_TOKEN=your_lomadee_app_token_here
LOMADEE_SOURCE_ID=your_source_id_here
LOMADEE_USE_MOCK=false

